generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  phone     String?
  bio       String?
  role      String   @default("admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model News {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  content   String
  image     String?
  categoryId String?
  category  Category? @relation(fields: [categoryId], references: [id])
  excerpt   String?
  author    String?
  tags      String?
  views     Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  news      News[]
}

model GalleryAlbum {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String?
  cover       String?
  eventDate   DateTime @default(now())
  images      GalleryImage[]
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model GalleryImage {
  id          String        @id @default(cuid())
  url         String
  title       String?
  description String?
  albumId     String?
  album       GalleryAlbum? @relation(fields: [albumId], references: [id], onDelete: Cascade)
  published   Boolean       @default(true)
  createdAt   DateTime      @default(now())
}

model Agenda {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String
  date        DateTime
  location    String
  image       String?
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Info {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  type      String   @default("text") // text, richtext, image
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserSettings {
  id        String   @id @default(cuid())
  userId    String   @unique
  
  // Notification preferences
  emailNotifications    Boolean @default(true)
  newsNotifications     Boolean @default(true)
  agendaNotifications   Boolean @default(true)
  commentNotifications  Boolean @default(false)
  weeklyNewsletter      Boolean @default(true)
  
  // UI preferences
  darkMode      Boolean @default(false)
  compactMode   Boolean @default(false)
  animations    Boolean @default(true)
  language      String  @default("id")
  itemsPerPage  Int     @default(10)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ContactMessage {
  id          String   @id @default(cuid())
  name        String
  email       String
  phone       String?
  categoryId  String?
  category    MessageCategory? @relation(fields: [categoryId], references: [id])
  subject     String
  message     String
  status      String   @default("new") // new, read, replied, archived
  adminNotes  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model MessageCategory {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  icon        String?
  published   Boolean  @default(true)
  order       Int      @default(0)
  messages    ContactMessage[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model OrganizationProfile {
  id              String   @id @default(cuid())
  // Contact Info
  email           String?
  emailSecondary  String?
  phone           String?
  phoneSecondary  String?
  whatsapp        String?
  whatsappSecondary String?
  
  // Address
  address         String?
  city            String?
  province        String?
  postalCode      String?
  
  // Social Media
  facebook        String?
  instagram       String?
  twitter         String?
  youtube         String?
  
  // About
  shortDescription String?
  longDescription  String?
  vision           String?
  mission          String?
  history          String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
